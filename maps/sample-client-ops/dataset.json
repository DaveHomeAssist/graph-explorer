    "id": "sample-client-ops",
    "name": "Sample: Client Operations Topology",
    "version": "1.0",
    "description": "Sample dataset showing a client-services org — revenue, delivery, support hubs with governance and operational data flows.",
    "author": "Digital Footprints LLC"
  },
  "nodes": [
    {
      "id": "exec-home",
      "label": "Executive Home",
      "type": "Top Hub",
      "layer": "Hub",
      "status": "Active",
      "meta": {
        "desc": "Primary entry point for leadership reporting, navigation, and cross-functional review.",
        "tags": ["dashboard", "leadership", "entry"],
        "risks": [
          "Too many KPIs on the front door can hide real exceptions",
          "Cross-functional links drift if ownership is not explicit"
        ],
        "nextMoves": [
          "Reduce duplicate metric cards across downstream hubs",
          "Add owner badges to linked operational surfaces"
        ],
        "owner": "Chief of Staff"
      }
    },
    {
      "id": "revenue-hub",
      "label": "Revenue Hub",
      "type": "Area Hub",
      "layer": "Hub",
      "status": "Active",
      "meta": {
        "desc": "Commercial operations hub for pipeline, client records, renewals, and billing handoff.",
        "tags": ["revenue", "sales", "finance"],
        "owner": "Revenue Operations"
      }
    },
    {
      "id": "delivery-hub",
      "label": "Delivery Hub",
      "type": "Area Hub",
      "layer": "Hub",
      "status": "Active",
      "meta": {
        "desc": "Operational hub for active delivery work, escalations, and service quality.",
        "tags": ["delivery", "operations", "services"],
        "owner": "Delivery Director"
      }
    },
