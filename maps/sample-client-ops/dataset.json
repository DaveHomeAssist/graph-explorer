      "type": "Control Panel",
      "layer": "Hub",
      "status": "At Risk",
      "meta": {
        "desc": "Daily operations control surface consolidating queue, incidents, flagship projects, and review artifacts.",
        "tags": ["control-panel", "ops", "daily-work"],
        "risks": [
          "Operational load is concentrated in a single surface",
          "Incident noise can obscure project blockers during peak volume",
          "Governance references are visible but not embedded into workflows"
        ],
        "nextMoves": [
          "Split queue and incident views by urgency tier",
          "Promote weekly review exceptions into a pinned summary strip",
          "Add SLA breach indicator for delivery queue cards"
        ],
        "owner": "Operations Manager"
      }
    },
    {
      "id": "support-ops-hub",
      "label": "Support Ops Hub",
